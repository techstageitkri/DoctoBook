generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  PENDING_VERIFICATION @map("pending_verification")
  PENDING_APPROVAL     @map("pending_approval")
  ACTIVE               @map("active")
  INACTIVE             @map("inactive")
  SUSPENDED            @map("suspended")
  DEACTIVATED          @map("deactivated")

  @@map("user_status")
}

enum ClinicStatus {
  DRAFT            @map("draft")
  PENDING_APPROVAL @map("pending_approval")
  ACTIVE           @map("active")
  SUSPENDED        @map("suspended")
  CLOSED           @map("closed")

  @@map("clinic_status")
}

enum DoctorStatus {
  PENDING_APPROVAL @map("pending_approval")
  APPROVED         @map("approved")
  REJECTED         @map("rejected")
  SUSPENDED        @map("suspended")

  @@map("doctor_status")
}

enum ClinicAssociationStatus {
  PENDING  @map("pending")
  APPROVED @map("approved")
  REJECTED @map("rejected")
  REMOVED  @map("removed")

  @@map("clinic_association_status")
}

enum AppointmentStatus {
  PENDING_PAYMENT      @map("pending_payment")
  CONFIRMED            @map("confirmed")
  CHECKED_IN           @map("checked_in")
  WAITING              @map("waiting")
  IN_PROGRESS          @map("in_progress")
  COMPLETED            @map("completed")
  CANCELLED_BY_PATIENT @map("cancelled_by_patient")
  CANCELLED_BY_CLINIC  @map("cancelled_by_clinic")
  CANCELLED_BY_ADMIN   @map("cancelled_by_admin")
  NO_SHOW              @map("no_show")
  EXPIRED              @map("expired")

  @@map("appointment_status")
}

enum AppointmentSource {
  PATIENT_WEB         @map("patient_web")
  DOCTOR_PORTAL       @map("doctor_portal")
  RECEPTIONIST_PORTAL @map("receptionist_portal")
  ADMIN_DASHBOARD     @map("admin_dashboard")
  MOBILE_APP          @map("mobile_app")
  IMPORTED            @map("imported")

  @@map("appointment_source")
}

enum PaymentMode {
  ONLINE_REQUIRED @map("online_required")
  PAY_AT_CLINIC   @map("pay_at_clinic")
  ONLINE_OPTIONAL @map("online_optional")

  @@map("payment_mode")
}

enum PaymentStatus {
  INITIATED          @map("initiated")
  PENDING            @map("pending")
  SUCCESSFUL         @map("successful")
  FAILED             @map("failed")
  CANCELLED          @map("cancelled")
  REFUNDED           @map("refunded")
  PARTIALLY_REFUNDED @map("partially_refunded")

  @@map("payment_status")
}

enum RefundStatus {
  REQUESTED    @map("requested")
  UNDER_REVIEW @map("under_review")
  APPROVED     @map("approved")
  REJECTED     @map("rejected")
  PROCESSING   @map("processing")
  PROCESSED    @map("processed")
  FAILED       @map("failed")

  @@map("refund_status")
}

enum ReviewStatus {
  PENDING_MODERATION @map("pending_moderation")
  APPROVED           @map("approved")
  REJECTED           @map("rejected")
  HIDDEN             @map("hidden")

  @@map("review_status")
}

enum NotificationChannel {
  EMAIL @map("email")
  SMS   @map("sms")
  PUSH  @map("push")

  @@map("notification_channel")
}

enum NotificationStatus {
  QUEUED     @map("queued")
  PROCESSING @map("processing")
  SENT       @map("sent")
  FAILED     @map("failed")
  CANCELLED  @map("cancelled")

  @@map("notification_status")
}

enum PermissionEffect {
  GRANT @map("grant")
  DENY  @map("deny")

  @@map("permission_effect")
}

enum ScopeType {
  PLATFORM        @map("platform")
  CLINIC          @map("clinic")
  CLINIC_LOCATION @map("clinic_location")
  DOCTOR          @map("doctor")
  PATIENT         @map("patient")
  APPOINTMENT     @map("appointment")

  @@map("scope_type")
}

enum FileVisibility {
  PRIVATE   @map("private")
  PROTECTED @map("protected")
  PUBLIC    @map("public")

  @@map("file_visibility")
}

enum DocumentReviewStatus {
  PENDING  @map("pending")
  APPROVED @map("approved")
  REJECTED @map("rejected")
  EXPIRED  @map("expired")

  @@map("document_review_status")
}

enum SlotHoldStatus {
  ACTIVE    @map("active")
  CONVERTED @map("converted")
  EXPIRED   @map("expired")
  RELEASED  @map("released")
  CANCELLED @map("cancelled")

  @@map("slot_hold_status")
}

enum RescheduleRequestStatus {
  REQUESTED @map("requested")
  APPROVED  @map("approved")
  REJECTED  @map("rejected")
  APPLIED   @map("applied")
  CANCELLED @map("cancelled")

  @@map("reschedule_request_status")
}

enum PaymentPurpose {
  APPOINTMENT           @map("appointment")
  RESCHEDULE_DIFFERENCE @map("reschedule_difference")

  @@map("payment_purpose")
}

enum ProviderType {
  PAYMENT @map("payment")
  EMAIL   @map("email")
  SMS     @map("sms")
  PUSH    @map("push")
  STORAGE @map("storage")

  @@map("provider_type")
}

model User {
  id              String     @id @default(uuid()) @db.Uuid
  email           String?    @db.Citext
  phone           String?    @db.VarChar(32)
  passwordHash    String?    @map("password_hash")
  fullName        String     @map("full_name") @db.VarChar(160)
  avatarFileId    String?    @map("avatar_file_id") @db.Uuid
  status          UserStatus @default(PENDING_VERIFICATION)
  emailVerifiedAt DateTime?  @map("email_verified_at") @db.Timestamptz(6)
  phoneVerifiedAt DateTime?  @map("phone_verified_at") @db.Timestamptz(6)
  lastLoginAt     DateTime?  @map("last_login_at") @db.Timestamptz(6)
  preferredLocale String     @default("en") @map("preferred_locale") @db.VarChar(16)
  createdAt       DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime   @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt       DateTime?  @map("deleted_at") @db.Timestamptz(6)

  avatarFile UploadedFile? @relation("UserAvatarFile", fields: [avatarFileId], references: [id], onDelete: SetNull)

  auditLogsActed                AuditLog[]                     @relation("AuditActor")
  authSessions                  AuthSession[]
  cancelledAppointments         Appointment[]                  @relation("AppointmentCancelledBy")
  clinicAdmins                  ClinicAdmin[]
  clinicsCreated                Clinic[]                       @relation("ClinicCreatedBy")
  consentRecords                ConsentRecord[]
  doctorDocumentClinicReviews   DoctorDocumentClinicReview[]   @relation("DoctorDocumentClinicReviewReviewer")
  doctorDocumentsReviewed       DoctorDocument[]               @relation("DoctorDocumentReviewedBy")
  doctorProfilesApproved        Doctor[]                       @relation("DoctorApprovedBy")
  notificationLogs              NotificationLog[]
  patientProfile                Patient?
  paymentsStatusChanged         PaymentStatusHistory[]         @relation("PaymentStatusHistoryActor")
  pushTokens                    UserPushToken[]
  receptionists                 Receptionist[]
  refundRequests                Refund[]                       @relation("RefundRequestedBy")
  refundReviews                 Refund[]                       @relation("RefundReviewedBy")
  refundStatusChanged           RefundStatusHistory[]          @relation("RefundStatusHistoryActor")
  reviewedReviews               Review[]                       @relation("ReviewModerator")
  roles                         UserRole[]
  settingsUpdated               SystemSetting[]                @relation("SystemSettingUpdatedBy")
  statusHistoryChanges          AppointmentStatusHistory[]     @relation("AppointmentStatusChangedBy")
  timeOffCreated                DoctorTimeOff[]                @relation("DoctorTimeOffCreatedBy")
  uploadedFiles                 UploadedFile[]                 @relation("UploadedFileUploadedBy")
  updatedAppointments           Appointment[]                  @relation("AppointmentUpdatedBy")
  userPermissionGrants          UserPermissionGrant[]          @relation("PermissionGrantTarget")
  userPermissionGrantsGiven     UserPermissionGrant[]          @relation("PermissionGrantGrantedBy")
  verificationTokens            VerificationToken[]
  providerConfigurationsUpdated ProviderConfiguration[]        @relation("ProviderConfigurationUpdatedBy")
  locationClosuresCreated       ClinicLocationClosure[]        @relation("ClinicLocationClosureCreatedBy")
  appointmentsCreated           Appointment[]                  @relation("AppointmentCreatedBy")
  rescheduleRequests            AppointmentRescheduleRequest[] @relation("RescheduleRequestedBy")
  doctorProfile                 Doctor?
  appointmentSlotHolds          AppointmentSlotHold[]

  @@index([status])
  @@index([avatarFileId])
  @@map("users")
}

model AuthSession {
  id               String    @id @default(uuid()) @db.Uuid
  userId           String    @map("user_id") @db.Uuid
  refreshTokenHash String    @unique @map("refresh_token_hash")
  deviceId         String?   @map("device_id") @db.VarChar(120)
  deviceName       String?   @map("device_name") @db.VarChar(160)
  ipAddress        String?   @map("ip_address") @db.Inet
  userAgent        String?   @map("user_agent")
  expiresAt        DateTime  @map("expires_at") @db.Timestamptz(6)
  revokedAt        DateTime? @map("revoked_at") @db.Timestamptz(6)
  lastUsedAt       DateTime? @map("last_used_at") @db.Timestamptz(6)
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([userId, revokedAt])
  @@index([expiresAt])
  @@map("auth_sessions")
}

model VerificationToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String?   @map("user_id") @db.Uuid
  tokenHash String    @unique @map("token_hash")
  purpose   String    @db.VarChar(64)
  email     String?   @db.Citext
  phone     String?   @db.VarChar(32)
  metadata  Json?
  expiresAt DateTime  @map("expires_at") @db.Timestamptz(6)
  usedAt    DateTime? @map("used_at") @db.Timestamptz(6)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  user User? @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([userId, purpose, createdAt])
  @@index([expiresAt])
  @@map("verification_tokens")
}

model Role {
  id          String   @id @default(uuid()) @db.Uuid
  code        String   @unique @db.VarChar(80)
  name        String   @db.VarChar(120)
  description String?
  isSystem    Boolean  @default(false) @map("is_system")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  permissions RolePermission[]
  users       UserRole[]

  @@map("roles")
}

model Permission {
  id          String   @id @default(uuid()) @db.Uuid
  code        String   @unique @db.VarChar(120)
  module      String   @db.VarChar(80)
  description String?
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  rolePermissions RolePermission[]
  userGrants      UserPermissionGrant[]

  @@index([module])
  @@map("permissions")
}

model UserRole {
  userId    String   @map("user_id") @db.Uuid
  roleId    String   @map("role_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@index([roleId])
  @@map("user_roles")
}

model RolePermission {
  roleId       String   @map("role_id") @db.Uuid
  permissionId String   @map("permission_id") @db.Uuid
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@index([permissionId])
  @@map("role_permissions")
}

model UserPermissionGrant {
  id              String           @id @default(uuid()) @db.Uuid
  userId          String           @map("user_id") @db.Uuid
  permissionId    String           @map("permission_id") @db.Uuid
  effect          PermissionEffect @default(GRANT)
  scopeType       ScopeType        @map("scope_type")
  scopeId         String?          @map("scope_id") @db.Uuid
  grantedByUserId String?          @map("granted_by_user_id") @db.Uuid
  reason          String?
  expiresAt       DateTime?        @map("expires_at") @db.Timestamptz(6)
  createdAt       DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  revokedAt       DateTime?        @map("revoked_at") @db.Timestamptz(6)

  grantedBy  User?      @relation("PermissionGrantGrantedBy", fields: [grantedByUserId], references: [id], onDelete: SetNull)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  user       User       @relation("PermissionGrantTarget", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, permissionId, scopeType, scopeId])
  @@index([scopeType, scopeId])
  @@index([expiresAt])
  @@map("user_permission_grants")
}

model UploadedFile {
  id               String         @id @default(uuid()) @db.Uuid
  uploadedByUserId String?        @map("uploaded_by_user_id") @db.Uuid
  storageProvider  String         @map("storage_provider") @db.VarChar(80)
  bucket           String?        @db.VarChar(160)
  objectKey        String         @map("object_key")
  originalFilename String         @map("original_filename") @db.VarChar(255)
  mimeType         String         @map("mime_type") @db.VarChar(120)
  sizeBytes        BigInt         @map("size_bytes")
  checksum         String?        @db.VarChar(160)
  visibility       FileVisibility @default(PRIVATE)
  createdAt        DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  deletedAt        DateTime?      @map("deleted_at") @db.Timestamptz(6)

  uploadedBy User? @relation("UploadedFileUploadedBy", fields: [uploadedByUserId], references: [id], onDelete: SetNull)

  clinicsAsLogo    Clinic[]         @relation("ClinicLogoFile")
  doctorDocuments  DoctorDocument[]
  doctorsAsProfile Doctor[]         @relation("DoctorProfileFile")
  usersAsAvatar    User[]           @relation("UserAvatarFile")

  @@index([uploadedByUserId])
  @@index([objectKey])
  @@map("uploaded_files")
}

model Patient {
  id                    String    @id @default(uuid()) @db.Uuid
  userId                String    @unique @map("user_id") @db.Uuid
  dateOfBirth           DateTime? @map("date_of_birth") @db.Date
  gender                String?   @db.VarChar(40)
  addressLine1          String?   @map("address_line1") @db.VarChar(180)
  addressLine2          String?   @map("address_line2") @db.VarChar(180)
  city                  String?   @db.VarChar(100)
  district              String?   @db.VarChar(100)
  country               String    @default("LK") @db.VarChar(2)
  emergencyContactName  String?   @map("emergency_contact_name") @db.VarChar(160)
  emergencyContactPhone String?   @map("emergency_contact_phone") @db.VarChar(32)
  createdAt             DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Restrict)

  appointments Appointment[]
  dependents   PatientDependent[]
  payments     Payment[]
  reviews      Review[]

  @@map("patients")
}

model PatientDependent {
  id                 String    @id @default(uuid()) @db.Uuid
  patientId          String    @map("patient_id") @db.Uuid
  fullName           String    @map("full_name") @db.VarChar(160)
  relationship       String    @db.VarChar(80)
  dateOfBirth        DateTime? @map("date_of_birth") @db.Date
  gender             String?   @db.VarChar(40)
  phone              String?   @db.VarChar(32)
  consentConfirmedAt DateTime? @map("consent_confirmed_at") @db.Timestamptz(6)
  isActive           Boolean   @default(true) @map("is_active")
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  appointments Appointment[]

  @@index([patientId, isActive])
  @@map("patient_dependents")
}

model Clinic {
  id                        String       @id @default(uuid()) @db.Uuid
  name                      String       @db.VarChar(180)
  slug                      String       @db.VarChar(180)
  description               String?
  logoFileId                String?      @map("logo_file_id") @db.Uuid
  status                    ClinicStatus @default(DRAFT)
  email                     String?      @db.Citext
  phone                     String?      @db.VarChar(32)
  websiteUrl                String?      @map("website_url")
  defaultPaymentMode        PaymentMode? @map("default_payment_mode")
  cancellationWindowMinutes Int?         @map("cancellation_window_minutes")
  refundProcessingDays      Int?         @map("refund_processing_days")
  createdByUserId           String?      @map("created_by_user_id") @db.Uuid
  createdAt                 DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                 DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt                 DateTime?    @map("deleted_at") @db.Timestamptz(6)

  createdBy User?         @relation("ClinicCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  logoFile  UploadedFile? @relation("ClinicLogoFile", fields: [logoFileId], references: [id], onDelete: SetNull)

  admins                ClinicAdmin[]
  appointments          Appointment[]
  clinicServices        ClinicService[]
  documentClinicReviews DoctorDocumentClinicReview[]
  doctorClinics         DoctorClinic[]
  locations             ClinicLocation[]
  receptionists         Receptionist[]
  reviews               Review[]

  @@index([status])
  @@index([slug])
  @@index([createdByUserId])
  @@map("clinics")
}

model ClinicLocation {
  id        String       @id @default(uuid()) @db.Uuid
  clinicId  String       @map("clinic_id") @db.Uuid
  name      String?      @db.VarChar(160)
  address   String
  city      String       @db.VarChar(100)
  district  String?      @db.VarChar(100)
  province  String?      @db.VarChar(100)
  country   String       @default("LK") @db.VarChar(2)
  timezone  String       @default("Asia/Colombo") @db.VarChar(80)
  latitude  Decimal?     @db.Decimal(9, 6)
  longitude Decimal?     @db.Decimal(9, 6)
  phone     String?      @db.VarChar(32)
  isPrimary Boolean      @default(false) @map("is_primary")
  status    ClinicStatus @default(ACTIVE)
  createdAt DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt DateTime?    @map("deleted_at") @db.Timestamptz(6)

  clinic Clinic @relation(fields: [clinicId], references: [id], onDelete: Restrict)

  appointments  Appointment[]
  closures      ClinicLocationClosure[]
  doctorClinics DoctorClinic[]
  hours         ClinicLocationHour[]
  receptionists Receptionist[]

  @@unique([id, clinicId])
  @@index([clinicId, status])
  @@index([city, district])
  @@map("clinic_locations")
}

model ClinicLocationHour {
  id            String    @id @default(uuid()) @db.Uuid
  locationId    String    @map("location_id") @db.Uuid
  dayOfWeek     Int       @map("day_of_week") @db.SmallInt
  opensAt       DateTime? @map("opens_at") @db.Time(0)
  closesAt      DateTime? @map("closes_at") @db.Time(0)
  isClosed      Boolean   @default(false) @map("is_closed")
  effectiveFrom DateTime? @map("effective_from") @db.Date
  effectiveTo   DateTime? @map("effective_to") @db.Date
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  location ClinicLocation @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@index([locationId, dayOfWeek])
  @@map("clinic_location_hours")
}

model ClinicLocationClosure {
  id              String   @id @default(uuid()) @db.Uuid
  locationId      String   @map("location_id") @db.Uuid
  startsAt        DateTime @map("starts_at") @db.Timestamptz(6)
  endsAt          DateTime @map("ends_at") @db.Timestamptz(6)
  reason          String?
  createdByUserId String?  @map("created_by_user_id") @db.Uuid
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  createdBy User?          @relation("ClinicLocationClosureCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  location  ClinicLocation @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@index([locationId, startsAt, endsAt])
  @@map("clinic_location_closures")
}

model ClinicAdmin {
  id        String                  @id @default(uuid()) @db.Uuid
  clinicId  String                  @map("clinic_id") @db.Uuid
  userId    String                  @map("user_id") @db.Uuid
  status    ClinicAssociationStatus @default(APPROVED)
  createdAt DateTime                @default(now()) @map("created_at") @db.Timestamptz(6)

  clinic Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([clinicId, userId])
  @@index([userId, status])
  @@map("clinic_admins")
}

model Receptionist {
  id               String                  @id @default(uuid()) @db.Uuid
  clinicId         String                  @map("clinic_id") @db.Uuid
  clinicLocationId String?                 @map("clinic_location_id") @db.Uuid
  userId           String                  @map("user_id") @db.Uuid
  status           ClinicAssociationStatus @default(APPROVED)
  createdAt        DateTime                @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime                @updatedAt @map("updated_at") @db.Timestamptz(6)

  clinic         Clinic          @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  clinicLocation ClinicLocation? @relation(fields: [clinicLocationId], references: [id], onDelete: SetNull)
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([clinicId, userId])
  @@index([clinicLocationId])
  @@index([userId, status])
  @@map("receptionists")
}

model Doctor {
  id               String       @id @default(uuid()) @db.Uuid
  userId           String       @unique @map("user_id") @db.Uuid
  slug             String       @db.VarChar(180)
  licenseNumber    String?      @map("license_number") @db.VarChar(120)
  status           DoctorStatus @default(PENDING_APPROVAL)
  bio              String?
  qualifications   String?
  yearsExperience  Int?         @map("years_experience")
  languages        String[]     @default([])
  profileFileId    String?      @map("profile_file_id") @db.Uuid
  approvedByUserId String?      @map("approved_by_user_id") @db.Uuid
  approvedAt       DateTime?    @map("approved_at") @db.Timestamptz(6)
  rejectionReason  String?      @map("rejection_reason")
  createdAt        DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt        DateTime?    @map("deleted_at") @db.Timestamptz(6)

  approvedBy  User?         @relation("DoctorApprovedBy", fields: [approvedByUserId], references: [id], onDelete: SetNull)
  profileFile UploadedFile? @relation("DoctorProfileFile", fields: [profileFileId], references: [id], onDelete: SetNull)
  user        User          @relation(fields: [userId], references: [id], onDelete: Restrict)

  appointments  Appointment[]
  clinics       DoctorClinic[]
  documents     DoctorDocument[]
  ratingSummary DoctorRatingSummary?
  reviews       Review[]
  specialties   DoctorSpecialty[]

  @@index([status])
  @@index([slug])
  @@map("doctors")
}

model DoctorDocument {
  id               String               @id @default(uuid()) @db.Uuid
  doctorId         String               @map("doctor_id") @db.Uuid
  fileId           String               @map("file_id") @db.Uuid
  documentType     String               @map("document_type") @db.VarChar(80)
  platformStatus   DocumentReviewStatus @default(PENDING) @map("platform_status")
