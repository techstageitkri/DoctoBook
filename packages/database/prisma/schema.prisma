  reviewedBy  User?       @relation("RefundReviewedBy", fields: [reviewedByUserId], references: [id], onDelete: SetNull)

  statusHistory RefundStatusHistory[]

  @@index([paymentId])
  @@index([appointmentId])
  @@index([status, requestedAt])
  @@index([provider, providerRefundId])
  @@map("refunds")
}

model PaymentStatusHistory {
  id             String         @id @default(uuid()) @db.Uuid
  paymentId      String         @map("payment_id") @db.Uuid
  fromStatus     PaymentStatus? @map("from_status")
  toStatus       PaymentStatus  @map("to_status")
  webhookEventId String?        @map("webhook_event_id") @db.Uuid
  actorUserId    String?        @map("actor_user_id") @db.Uuid
  reason         String?
  metadata       Json?
  createdAt      DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)

  actor        User?                @relation("PaymentStatusHistoryActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  payment      Payment              @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  webhookEvent PaymentWebhookEvent? @relation(fields: [webhookEventId], references: [id], onDelete: SetNull)

  @@index([paymentId, createdAt])
  @@map("payment_status_history")
}

model RefundStatusHistory {
  id          String        @id @default(uuid()) @db.Uuid
  refundId    String        @map("refund_id") @db.Uuid
  fromStatus  RefundStatus? @map("from_status")
  toStatus    RefundStatus  @map("to_status")
  actorUserId String?       @map("actor_user_id") @db.Uuid
  reason      String?
  metadata    Json?
  createdAt   DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)

  actor  User?  @relation("RefundStatusHistoryActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  refund Refund @relation(fields: [refundId], references: [id], onDelete: Cascade)

  @@index([refundId, createdAt])
  @@map("refund_status_history")
}

model Review {
  id               String       @id @default(uuid()) @db.Uuid
  appointmentId    String       @unique @map("appointment_id") @db.Uuid
  patientId        String       @map("patient_id") @db.Uuid
  doctorId         String       @map("doctor_id") @db.Uuid
  clinicId         String       @map("clinic_id") @db.Uuid
  rating           Int          @db.SmallInt
  title            String?      @db.VarChar(160)
  comment          String?
  status           ReviewStatus @default(PENDING_MODERATION)
  moderatorUserId  String?      @map("moderator_user_id") @db.Uuid
  moderatedAt      DateTime?    @map("moderated_at") @db.Timestamptz(6)
  moderationReason String?      @map("moderation_reason")
  createdAt        DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)

  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  clinic      Clinic      @relation(fields: [clinicId], references: [id], onDelete: Restrict)
  doctor      Doctor      @relation(fields: [doctorId], references: [id], onDelete: Restrict)
  moderator   User?       @relation("ReviewModerator", fields: [moderatorUserId], references: [id], onDelete: SetNull)
  patient     Patient     @relation(fields: [patientId], references: [id], onDelete: Restrict)

  @@index([doctorId, status])
  @@index([clinicId, status])
  @@index([patientId])
  @@map("reviews")
}

model DoctorRatingSummary {
  doctorId      String   @id @map("doctor_id") @db.Uuid
  averageRating Decimal  @default(0) @map("average_rating") @db.Decimal(3, 2)
  reviewCount   Int      @default(0) @map("review_count")
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  doctor Doctor @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@map("doctor_rating_summaries")
}

model NotificationTemplate {
  id        String              @id @default(uuid()) @db.Uuid
  scopeType ScopeType           @map("scope_type")
  scopeId   String?             @map("scope_id") @db.Uuid
  eventCode String              @map("event_code") @db.VarChar(120)
  channel   NotificationChannel
  locale    String              @default("en") @db.VarChar(16)
  subject   String?
  body      String
  isActive  Boolean             @default(true) @map("is_active")
  createdAt DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime            @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@unique([scopeType, scopeId, eventCode, channel, locale])
  @@index([eventCode, channel])
  @@map("notification_templates")
}

model NotificationLog {
  id                String              @id @default(uuid()) @db.Uuid
  userId            String?             @map("user_id") @db.Uuid
  appointmentId     String?             @map("appointment_id") @db.Uuid
  channel           NotificationChannel
  eventCode         String              @map("event_code") @db.VarChar(120)
  idempotencyKey    String?             @unique @map("idempotency_key") @db.VarChar(160)
  recipient         String
  subject           String?
  body              String?
  status            NotificationStatus  @default(QUEUED)
  provider          String?             @db.VarChar(80)
  providerMessageId String?             @map("provider_message_id") @db.VarChar(160)
  error             String?
  attempts          Int                 @default(0)
  scheduledAt       DateTime?           @map("scheduled_at") @db.Timestamptz(6)
  sentAt            DateTime?           @map("sent_at") @db.Timestamptz(6)
  createdAt         DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime            @updatedAt @map("updated_at") @db.Timestamptz(6)

  appointment Appointment? @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  user        User?        @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([appointmentId])
  @@index([status, scheduledAt])
  @@map("notification_logs")
}

model UserPushToken {
  id         String    @id @default(uuid()) @db.Uuid
  userId     String    @map("user_id") @db.Uuid
  token      String    @unique
  platform   String    @db.VarChar(40)
  deviceId   String?   @map("device_id") @db.VarChar(120)
  isActive   Boolean   @default(true) @map("is_active")
  lastSeenAt DateTime? @map("last_seen_at") @db.Timestamptz(6)
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isActive])
  @@map("user_push_tokens")
}

model SystemSetting {
  id              String    @id @default(uuid()) @db.Uuid
  scopeType       ScopeType @map("scope_type")
  scopeId         String?   @map("scope_id") @db.Uuid
  key             String    @db.VarChar(160)
  value           Json
  isEncrypted     Boolean   @default(false) @map("is_encrypted")
  updatedByUserId String?   @map("updated_by_user_id") @db.Uuid
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  updatedBy User? @relation("SystemSettingUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)

  @@unique([scopeType, scopeId, key])
  @@index([scopeType, scopeId])
  @@map("system_settings")
}

model ProviderConfiguration {
  id              String       @id @default(uuid()) @db.Uuid
  providerType    ProviderType @map("provider_type")
  providerCode    String       @map("provider_code") @db.VarChar(80)
  scopeType       ScopeType    @map("scope_type")
  scopeId         String?      @map("scope_id") @db.Uuid
  displayName     String       @map("display_name") @db.VarChar(160)
  config          Json
  isActive        Boolean      @default(true) @map("is_active")
  isEncrypted     Boolean      @default(true) @map("is_encrypted")
  updatedByUserId String?      @map("updated_by_user_id") @db.Uuid
  createdAt       DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)

  updatedBy User? @relation("ProviderConfigurationUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)

  @@unique([providerType, providerCode, scopeType, scopeId])
  @@index([providerType, isActive])
  @@index([scopeType, scopeId])
  @@map("provider_configurations")
}

model AuditLog {
  id            String   @id @default(uuid()) @db.Uuid
  actorUserId   String?  @map("actor_user_id") @db.Uuid
  actorRole     String?  @map("actor_role") @db.VarChar(80)
  actionCode    String   @map("action_code") @db.VarChar(120)
  entityType    String   @map("entity_type") @db.VarChar(120)
  entityId      String?  @map("entity_id") @db.Uuid
  clinicId      String?  @map("clinic_id") @db.Uuid
  patientId     String?  @map("patient_id") @db.Uuid
  ipAddress     String?  @map("ip_address") @db.Inet
  userAgent     String?  @map("user_agent")
  correlationId String?  @map("correlation_id") @db.VarChar(160)
  beforeData    Json?    @map("before_data")
  afterData     Json?    @map("after_data")
  metadata      Json?
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  actor User? @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([actorUserId, createdAt])
  @@index([clinicId, createdAt])
  @@index([patientId, createdAt])
  @@index([entityType, entityId])
  @@index([actionCode, createdAt])
  @@map("audit_logs")
}

model ConsentRecord {
  id          String    @id @default(uuid()) @db.Uuid
  userId      String    @map("user_id") @db.Uuid
  consentType String    @map("consent_type") @db.VarChar(120)
  version     String    @db.VarChar(40)
  accepted    Boolean
  recordedAt  DateTime  @default(now()) @map("recorded_at") @db.Timestamptz(6)
  withdrawnAt DateTime? @map("withdrawn_at") @db.Timestamptz(6)
  ipAddress   String?   @map("ip_address") @db.Inet
  userAgent   String?   @map("user_agent")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, consentType, recordedAt])
  @@map("consent_records")
}

model Translation {
  id         String   @id @default(uuid()) @db.Uuid
  entityType String   @map("entity_type") @db.VarChar(120)
  entityId   String?  @map("entity_id") @db.Uuid
  fieldName  String   @map("field_name") @db.VarChar(120)
  locale     String   @db.VarChar(16)
  value      String
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@unique([entityType, entityId, fieldName, locale])
  @@index([locale])
  @@map("translations")
}
