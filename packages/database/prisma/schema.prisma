generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String   @id @default(uuid()) @db.Uuid
  email           String?  @db.Citext
  phone           String?  @db.VarChar(32)
  passwordHash    String?  @map("password_hash")
  fullName        String   @map("full_name") @db.VarChar(160)
  status          String   @default("pending_verification") @db.VarChar(40)
  preferredLocale String   @default("en") @map("preferred_locale") @db.VarChar(16)
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz

  authSessions       AuthSession[]
  verificationTokens VerificationToken[]

  @@map("users")
}

model AuthSession {
  id               String    @id @default(uuid()) @db.Uuid
  userId           String    @map("user_id") @db.Uuid
  refreshTokenHash String    @unique @map("refresh_token_hash")
  deviceId         String?   @map("device_id") @db.VarChar(120)
  deviceName       String?   @map("device_name") @db.VarChar(160)
  ipAddress        String?   @map("ip_address") @db.Inet
  userAgent        String?   @map("user_agent")
  expiresAt        DateTime  @map("expires_at") @db.Timestamptz
  revokedAt        DateTime? @map("revoked_at") @db.Timestamptz
  lastUsedAt       DateTime? @map("last_used_at") @db.Timestamptz
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([userId, revokedAt])
  @@index([expiresAt])
  @@map("auth_sessions")
}

model VerificationToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String?   @map("user_id") @db.Uuid
  tokenHash String    @unique @map("token_hash")
  purpose   String    @db.VarChar(64)
  email     String?   @db.Citext
  phone     String?   @db.VarChar(32)
  metadata  Json?
  expiresAt DateTime  @map("expires_at") @db.Timestamptz
  usedAt    DateTime? @map("used_at") @db.Timestamptz
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz

  user User? @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([userId, purpose, createdAt])
  @@index([expiresAt])
  @@map("verification_tokens")
}
