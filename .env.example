NODE_ENV=development

POSTGRES_DB=doctobook
POSTGRES_USER=doctobook
POSTGRES_PASSWORD=doctobook
DATABASE_URL=postgresql://doctobook:doctobook@localhost:5432/doctobook?schema=public

REDIS_URL=redis://localhost:6379

API_HOST=127.0.0.1
API_PORT=4001
WEB_HOST=127.0.0.1
WEB_PORT=3002
NEXT_PUBLIC_API_URL=http://127.0.0.1:4001
WEB_PUBLIC_URL=http://127.0.0.1:3002

JWT_ACCESS_TOKEN_SECRET=change-me-access
JWT_REFRESH_TOKEN_SECRET=change-me-refresh
SESSION_REFRESH_TOKEN_DAYS=30

ENCRYPTION_KEY=change-me-32-byte-key

PAYMENT_PROVIDER=mock
PAYHERE_MERCHANT_ID=
PAYHERE_MERCHANT_SECRET=
PAYHERE_CHECKOUT_URL=https://sandbox.payhere.lk/pay/checkout
PAYHERE_NOTIFY_URL=http://127.0.0.1:4001/v1/payments/webhooks/payhere
PAYMENT_RETURN_URL=http://127.0.0.1:3002/patient/payments/return
PAYMENT_CANCEL_URL=http://127.0.0.1:3002/patient/payments/cancel
PAYHERE_DEFAULT_PHONE=0771234567
PAYHERE_DEFAULT_ADDRESS=N/A
PAYHERE_DEFAULT_CITY=Colombo
PAYHERE_DEFAULT_COUNTRY=Sri Lanka
